<!doctype html>
<html>
  <head>
    <meta charset="utf-8" />
    <title>Quote Comparison Sheet</title>
    <style>
      body { font-family: Arial, Helvetica, sans-serif; }
      table { border-collapse: collapse; width: 100%; }
      th, td { border: 1px solid #d9d9d9; padding: 8px; }
      th { background: #f3f3f3; text-align: left; }
    </style>
  </head>
  <body>
    <table>
      <tr>
        <th>Line item</th>
        <th>Supplier A</th>
        <th>Supplier B</th>
        <th>Supplier C</th>
        <th>Notes</th>
      </tr>
      <tr><td>Base machine model</td><td></td><td></td><td></td><td></td></tr>
      <tr><td>Capacity (bpm)</td><td></td><td></td><td></td><td>Define conditions</td></tr>
      <tr><td>Accuracy / tolerance</td><td></td><td></td><td></td><td>Sampling plan</td></tr>
      <tr><td>Dust/drip control</td><td></td><td></td><td></td><td>Seal stability</td></tr>
      <tr><td>Inspection modules</td><td></td><td></td><td></td><td>MD/CW/Vision</td></tr>
      <tr><td>Changeover design</td><td></td><td></td><td></td><td>Time + parts</td></tr>
      <tr><td>Documentation package</td><td></td><td></td><td></td><td>Manual/diagrams/spares</td></tr>
      <tr><td>FAT acceptance criteria</td><td></td><td></td><td></td><td>Pass/fail</td></tr>
      <tr><td>Lead time</td><td></td><td></td><td></td><td>By milestone</td></tr>
      <tr><td>Payment terms</td><td></td><td></td><td></td><td>Tie to evidence</td></tr>
      <tr><td>Warranty + after-sales</td><td></td><td></td><td></td><td>Response time</td></tr>
    </table>
  </body>
</html>

