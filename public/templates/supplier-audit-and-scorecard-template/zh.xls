<!doctype html>
<html>
  <head>
    <meta charset="utf-8" />
    <title>供應商稽核評分表</title>
    <style>
      body { font-family: Arial, Helvetica, sans-serif; }
      table { border-collapse: collapse; width: 100%; }
      th, td { border: 1px solid #d9d9d9; padding: 8px; }
      th { background: #f3f3f3; text-align: left; }
    </style>
  </head>
  <body>
    <table>
      <tr><th>項目</th><th>權重</th><th>看什麼</th></tr>
      <tr><td>技術適配</td><td>30%</td><td>相似案例/工程邏輯/接口理解</td></tr>
      <tr><td>品質系統</td><td>25%</td><td>檢核表/來料檢驗/配線紀律/版本控管</td></tr>
      <tr><td>驗收能力</td><td>25%</td><td>FAT 計畫/抽樣/偏差清單與複測</td></tr>
      <tr><td>交付與售後</td><td>20%</td><td>文件包/備品/回覆流程/升級機制</td></tr>
    </table>
  </body>
</html>

