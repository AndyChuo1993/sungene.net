<!doctype html>
<html>
  <head>
    <meta charset="utf-8" />
    <title>供应商稽核评分表</title>
    <style>
      body { font-family: Arial, Helvetica, sans-serif; }
      table { border-collapse: collapse; width: 100%; }
      th, td { border: 1px solid #d9d9d9; padding: 8px; }
      th { background: #f3f3f3; text-align: left; }
    </style>
  </head>
  <body>
    <table>
      <tr><th>项目</th><th>权重</th><th>看什么</th></tr>
      <tr><td>技术适配</td><td>30%</td><td>相似案例/工程逻辑/接口理解</td></tr>
      <tr><td>质量系统</td><td>25%</td><td>检查表/来料检验/配线纪律/版本控制</td></tr>
      <tr><td>验收能力</td><td>25%</td><td>FAT 计划/抽样/偏差清单与复测</td></tr>
      <tr><td>交付与售后</td><td>20%</td><td>文件包/备品/回复流程/升级机制</td></tr>
    </table>
  </body>
</html>

