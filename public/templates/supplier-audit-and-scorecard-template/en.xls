<!doctype html>
<html>
  <head>
    <meta charset="utf-8" />
    <title>Supplier Audit & Scorecard</title>
    <style>
      body { font-family: Arial, Helvetica, sans-serif; }
      table { border-collapse: collapse; width: 100%; }
      th, td { border: 1px solid #d9d9d9; padding: 8px; }
      th { background: #f3f3f3; text-align: left; }
    </style>
  </head>
  <body>
    <table>
      <tr><th>Category</th><th>Weight</th><th>What to look for</th></tr>
      <tr><td>Technical fit</td><td>30%</td><td>Similar references, engineering clarity, interface understanding</td></tr>
      <tr><td>Quality system</td><td>25%</td><td>Checklists, incoming inspection, wiring discipline, revision control</td></tr>
      <tr><td>Acceptance capability</td><td>25%</td><td>FAT plan, sampling, deviation log and retest</td></tr>
      <tr><td>Delivery &amp; service</td><td>20%</td><td>Document package, spares, response workflow, escalation</td></tr>
    </table>
  </body>
</html>

